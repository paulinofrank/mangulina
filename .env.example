# Mangulina environment template.
# Copy to .env and fill in real values. This file is committed — it must
# contain PLACEHOLDERS ONLY, never real keys, tokens, or passwords.

# ---------------------------------------------------------------------------
# FRONTEND (Next.js browser) — build-time variables; changing them requires a
# redeployment because Next.js inlines NEXT_PUBLIC_* values into the bundle.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_SITE_URL=https://mangulina.vercel.app
# Enables the admin analytics "Open Vercel Dashboard" button.
NEXT_PUBLIC_VERCEL_DASHBOARD_URL=https://vercel.com/dashboard

# Set to "true" in the PRODUCTION environment only. Leave unset/blank in local
# dev and Vercel preview deployments so they never write into production
# Supabase analytics tables. Build-time: requires a redeployment to change.
NEXT_PUBLIC_ENABLE_ANALYTICS=

# ---------------------------------------------------------------------------
# Analytics endpoint security (POST /api/analytics/track) — server-side only.
# None of these may ever use a NEXT_PUBLIC_ prefix.
# ---------------------------------------------------------------------------

# Salted one-way hash input for privacy-preserving IP hashing. REQUIRED in
# Production (without it, per-IP rate limiting is skipped and only per-session
# limiting applies — the endpoint logs this reduced-protection state).
# Runtime variable: changing it does NOT require a redeployment, but changing
# it breaks continuity with previously stored ip_hash values.
ANALYTICS_IP_HASH_SALT=generate-a-long-random-string

# Set to "true" to log accepted/deduplicated analytics events too (default
# logs only rejections and errors). Keep unset in Production unless actively
# debugging. Runtime variable.
ANALYTICS_DEBUG=

# NOTE: rate limiting is currently in-memory per serverless instance
# (best-effort). A distributed limiter is deferred; no configuration exists
# for it yet.

# ---------------------------------------------------------------------------
# BACKEND (Node scripts and server-side code) — runtime variables.
# ---------------------------------------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
MANGULINA_ADMIN_EMAILS=admin@example.com

MUSICBRAINZ_USER_AGENT=MangulinaIngest/1.0 (contact@example.com)
DELAY_MS=2000
TEST_MODE=false
TEST_LIMIT=10
COVER_ART_BUCKET=cover-art

DATABASE_URL=postgresql://user:password@host:5432/postgres

DISCOGS_TOKEN=your-discogs-token

# Spotify API credentials
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# YouTube API Keys
# Single key (if using one key only)
YOUTUBE_API_KEY=your-youtube-api-key
# Multiple keys for quota rotation, comma-separated (used by
# populate_youtube_links.py for high-volume link population)
YOUTUBE_API_KEYS_CSV=key1,key2,key3
